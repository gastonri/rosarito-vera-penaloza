---
interface Props {
  title?: string;
  subtitle?: string;
  showLevel?: boolean;
}

const {
  title = 'Envianos tu consulta',
  subtitle = 'Completá el formulario y te respondemos a la brevedad.',
  showLevel = false,
} = Astro.props;
---

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <h3 class="font-heading font-700 text-2xl text-brand-dark mb-1">{title}</h3>
  <p class="text-gray-500 text-sm mb-8">{subtitle}</p>

  <!--
    NOTA TÉCNICA: Este formulario está preparado para integrarse con:
    - Netlify Forms: agregar `netlify` o `data-netlify="true"` al <form>
    - Formspree: reemplazar action="#" por "https://formspree.io/f/TU_ID"
    Actualizar cuando se defina el hosting.
  -->
  <form
    id="contact-form"
    method="POST"
    action="#"
    class="space-y-5"
    novalidate
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="nombre" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
          Nombre <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          autocomplete="given-name"
          placeholder="Tu nombre"
          class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition"
        />
      </div>
      <div>
        <label for="apellido" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
          Apellido <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="apellido"
          name="apellido"
          required
          autocomplete="family-name"
          placeholder="Tu apellido"
          class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="email" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
          Email <span class="text-red-400">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="tu@email.com"
          class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition"
        />
      </div>
      <div>
        <label for="telefono" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
          Teléfono
        </label>
        <input
          type="tel"
          id="telefono"
          name="telefono"
          autocomplete="tel"
          placeholder="+54 351 000-0000"
          class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition"
        />
      </div>
    </div>

    {showLevel && (
      <div>
        <label for="nivel" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
          Nivel de interés <span class="text-red-400">*</span>
        </label>
        <select
          id="nivel"
          name="nivel"
          required
          class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition bg-white"
        >
          <option value="">Seleccioná un nivel</option>
          <option value="maternal">Nivel Inicial – Maternal (45 días a 2 años)</option>
          <option value="jardin">Nivel Inicial – Jardín (3 a 5 años)</option>
          <option value="primario">Nivel Primario (1° a 6° grado)</option>
          <option value="secundario">Nivel Secundario (1° a 6° año)</option>
        </select>
      </div>
    )}

    <div>
      <label for="mensaje" class="block text-sm font-heading font-600 text-gray-700 mb-1.5">
        Mensaje <span class="text-red-400">*</span>
      </label>
      <textarea
        id="mensaje"
        name="mensaje"
        required
        rows="4"
        placeholder="¿En qué podemos ayudarte?"
        class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 transition resize-none"
      ></textarea>
    </div>

    <button
      type="submit"
      class="w-full sm:w-auto px-8 py-3 rounded-full bg-brand text-white font-heading font-600 text-sm hover:bg-brand-dark transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-brand/40"
    >
      Enviar mensaje
    </button>
  </form>
</div>
