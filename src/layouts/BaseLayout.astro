---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Colegio de Educación Privada en Córdoba, Argentina. Nivel Inicial, Primario y Secundario. Un proyecto educativo que privilegia el Saber, el Sentir, el Ser y el Hacer.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://colegiorosarito.edu.ar');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/assets/img/logo.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Colegio Rosarito Vera Peñaloza`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Open+Sans:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Colegio Rosarito Vera Peñaloza</title>
  </head>
  <body class="bg-white text-gray-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
