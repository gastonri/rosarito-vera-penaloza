---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contacto"
  description="Contacto del Colegio Rosarito Vera Peñaloza en Córdoba. Viracocha 6933, Quintas de Argüello. Teléfono, WhatsApp y formulario de contacto."
>

  <!-- HERO -->
  <section class="py-20 bg-brand-50 border-b border-brand-pale">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href="/" class="inline-flex items-center gap-2 text-brand/60 text-sm hover:text-brand transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al inicio
      </a>
      <h1 class="font-heading font-800 text-4xl sm:text-5xl text-brand-dark mb-4">Contacto</h1>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        Estamos para responder tus consultas, coordinar visitas e informarte sobre inscripciones.
      </p>
    </div>
  </section>

  <!-- INFO + FORMULARIO -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Datos de contacto -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="font-heading font-700 text-2xl text-brand-dark mb-6">Encontranos</h2>

            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-pale flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Dirección</p>
                  <p class="text-gray-500 text-sm mt-0.5">{site.address}</p>
                  <p class="text-gray-400 text-xs mt-0.5">Barrio El Refugio, norte de Córdoba Capital</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-pale flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Horario</p>
                  <p class="text-gray-500 text-sm mt-0.5">{site.schedule}</p>
                  <p class="text-gray-400 text-xs mt-0.5">Lunes a viernes</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-pale flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Teléfono / WhatsApp</p>
                  <a href={site.whatsapp} target="_blank" rel="noopener noreferrer" class="text-brand text-sm mt-0.5 hover:underline block">{site.phone}</a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-pale flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Email general</p>
                  <a href={`mailto:${site.email}`} class="text-brand text-sm mt-0.5 hover:underline block break-all">{site.email}</a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-brand-pale flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Email admisiones</p>
                  <a href={`mailto:${site.admissionsEmail}`} class="text-brand text-sm mt-0.5 hover:underline block break-all">{site.admissionsEmail}</a>
                </div>
              </li>
            </ul>
          </div>

          <!-- Redes -->
          <div>
            <h3 class="font-heading font-600 text-gray-800 mb-4 text-sm">Seguinos en redes</h3>
            <div class="flex gap-3">
              <a
                href={site.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-brand-50 border border-brand-pale text-brand text-sm font-heading font-600 hover:bg-brand-pale transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
              <a
                href={site.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-brand-50 border border-brand-pale text-brand text-sm font-heading font-600 hover:bg-brand-pale transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Instagram
              </a>
            </div>
          </div>
        </div>

        <!-- Formulario -->
        <div class="lg:col-span-3">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- MAPA -->
  <section class="bg-gray-100 h-80 relative overflow-hidden">
    <!-- Placeholder mapa — reemplazar con iframe de Google Maps -->
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-brand-50">
      <svg class="w-12 h-12 text-brand/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
      </svg>
      <div class="text-center">
        <p class="text-brand font-heading font-600 text-sm">Viracocha 6933, Quintas de Argüello</p>
        <p class="text-gray-400 text-xs mt-1">Córdoba Capital, Argentina</p>
        <a
          href="https://maps.google.com/?q=Viracocha+6933+Quintas+de+Argüello+Córdoba+Argentina"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 mt-3 text-brand text-xs font-heading font-600 hover:underline"
        >
          Ver en Google Maps →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
