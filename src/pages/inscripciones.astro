---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Inscripciones"
  description="Inscripciones al Colegio Rosarito Vera Peñaloza. Nivel Inicial, Primario y Secundario en Córdoba. Conocé el proceso y completá tu solicitud."
>

  <!-- HERO -->
  <section class="relative py-24 bg-accent overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full -translate-y-1/2 translate-x-1/2"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href={base} class="inline-flex items-center gap-2 text-white/80 text-sm hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al inicio
      </a>
      <h1 class="font-heading font-800 text-4xl sm:text-5xl text-white mb-4">Inscripciones</h1>
      <p class="text-white/80 text-lg max-w-xl mx-auto">
        Sumá a tu hijo/a a la comunidad del Colegio Rosarito Vera Peñaloza.
      </p>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-accent font-heading font-600 text-sm uppercase tracking-widest">Cómo inscribirse</span>
        <h2 class="font-heading font-700 text-3xl sm:text-4xl text-brand-dark mt-3">El proceso paso a paso</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Tomá contacto', desc: 'Escribinos por formulario, email o WhatsApp para obtener información sobre el nivel y vacantes disponibles.' },
          { step: '02', title: 'Visitá el colegio', desc: 'Coordinamos una visita para que conozcas las instalaciones, el equipo docente y la propuesta educativa.' },
          { step: '03', title: 'Entrega de documentación', desc: 'Una vez confirmada la vacante, completás la documentación requerida para formalizar la inscripción.' },
          { step: '04', title: '¡Bienvenido/a!', desc: 'Tu hijo/a ya es parte de la comunidad Rosarito. Te informamos sobre el comienzo del ciclo lectivo.' },
        ].map(item => (
          <div class="relative">
            <div class="bg-brand-50 rounded-2xl p-6 h-full border border-brand-pale">
              <div class="text-5xl font-heading font-800 text-brand/20 mb-4">{item.step}</div>
              <h3 class="font-heading font-700 text-brand-dark mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCUMENTACIÓN -->
  <section class="py-16 bg-brand-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-heading font-700 text-2xl sm:text-3xl text-brand-dark">Documentación necesaria</h2>
        <p class="text-gray-500 mt-3 text-sm">
          Los requisitos pueden variar según el nivel. Te informamos en detalle al confirmar la vacante.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            nivel: 'Nivel Inicial',
            docs: ['DNI del alumno/a (copia)', 'Partida de nacimiento', 'Certificado de vacunación', 'DNI de los padres/tutores', 'Ficha médica'],
          },
          {
            nivel: 'Nivel Primario',
            docs: ['DNI del alumno/a (copia)', 'Partida de nacimiento', 'Certificado de vacunación', 'Boletín del año anterior', 'Ficha de salud'],
          },
          {
            nivel: 'Nivel Secundario',
            docs: ['DNI del alumno/a (copia)', 'Certificado de estudios primarios', 'Boletín del año anterior', 'Ficha de salud', 'Foto carnet'],
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-6 border border-brand-pale shadow-sm">
            <h3 class="font-heading font-700 text-brand-dark mb-4">{item.nivel}</h3>
            <ul class="space-y-2">
              {item.docs.map(doc => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  {doc}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMULARIO + DATOS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Form -->
        <div class="lg:col-span-3">
          <ContactForm
            title="Solicitá información"
            subtitle="Completá el formulario y te contactamos a la brevedad para indicarte disponibilidad y pasos a seguir."
            showLevel={true}
          />
        </div>

        <!-- Contacto directo -->
        <div class="lg:col-span-2 space-y-6">
          <div>
            <h3 class="font-heading font-700 text-xl text-brand-dark mb-5">Contacto directo</h3>

            <div class="space-y-4">
              <a
                href={site.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 bg-green-50 rounded-xl border border-green-100 hover:border-green-200 transition-colors group"
              >
                <div class="w-10 h-10 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">WhatsApp</p>
                  <p class="text-gray-500 text-sm">{site.phone}</p>
                </div>
              </a>

              <a
                href={`mailto:${site.admissionsEmail}`}
                class="flex items-center gap-4 p-4 bg-brand-50 rounded-xl border border-brand-pale hover:border-brand-light transition-colors group"
              >
                <div class="w-10 h-10 rounded-full bg-brand flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading font-600 text-gray-800 text-sm">Email de admisiones</p>
                  <p class="text-gray-500 text-sm break-all">{site.admissionsEmail}</p>
                </div>
              </a>
            </div>
          </div>

          <div class="bg-accent-pale rounded-2xl p-6 border border-accent/20">
            <h4 class="font-heading font-700 text-accent-dark mb-2 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Importante
            </h4>
            <p class="text-gray-600 text-sm leading-relaxed">
              Las vacantes son limitadas. Te recomendamos consultar con anticipación para asegurar el lugar de tu hijo/a en el nivel que corresponda.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
